# Copy this file to .env and fill in your backend URL and Qwen key.
# After editing .env, restart Metro: CI=false npx expo start --clear

# Qwen / DashScope key used by Lambda after deploy.
EXPO_PUBLIC_DASHSCOPE_API_KEY=your_dashscope_api_key_here

# AWS · API Gateway invoke URL
# Required for live sharing, uploads, wallet sync, and AI proxying.
EXPO_PUBLIC_AWS_API_URL=
