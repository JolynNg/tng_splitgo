# Copy this file to .env and fill in your keys.
# After editing .env, restart Metro: CI=false npx expo start --clear

# Alibaba Cloud · Model Studio (Qwen-VL receipt OCR) — REQUIRED
# Sign up at alibabacloud.com → activate Model Studio → API-KEY → Create
EXPO_PUBLIC_DASHSCOPE_API_KEY=your_dashscope_api_key_here

# AWS · API Gateway invoke URL (live bill-session backend) — OPTIONAL
# After deploying Lambda + API Gateway (see BACKEND_SETUP.md) paste the URL.
# If unset, the app runs in local demo mode using the in-app user switcher.
EXPO_PUBLIC_AWS_API_URL=
